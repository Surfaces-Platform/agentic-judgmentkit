  "context_heading": "Loaded context",
  "context_support": "JudgmentKit loads the workflow, linked guardrails, and the calibration example before generation starts.",
  "install_targets": [
    {
      "id": "codex",
      "label": "Codex",
      "transport": "stdio",
      "connection_label": "Command",
      "connection_value": "npm --prefix <ABSOLUTE_PATH_TO_LOCAL_JUDGMENTKIT_CHECKOUT> run mcp:stdio",
      "config_path": "~/.codex/config.toml",
      "install_note": "Save the file and restart Codex. Use the packaged mcp:stdio script and avoid wrappers that open auxiliary IPC listeners before stdio starts.",
      "config_snippet": "[mcp_servers.judgmentkit]\ncommand = \"npm\"\nargs = [\"--prefix\", \"<ABSOLUTE_PATH_TO_LOCAL_JUDGMENTKIT_CHECKOUT>\", \"run\", \"mcp:stdio\"]",
      "starter_call": "get_workflow_bundle({ workflow_id: \"workflow.ai-ui-generation\" })"
    },
    {
      "id": "claude",
      "label": "Claude",
      "transport": "stdio",
      "connection_label": "Command",
      "connection_value": "npm --prefix <ABSOLUTE_PATH_TO_LOCAL_JUDGMENTKIT_CHECKOUT> run mcp:stdio",
      "config_path": ".mcp.json",
      "install_note": "Save the file and restart Claude. Use the packaged mcp:stdio script and avoid wrappers that open auxiliary IPC listeners before stdio starts.",
      "config_snippet": "{\n  \"mcpServers\": {\n    \"judgmentkit\": {\n      \"command\": \"npm\",\n      \"args\": [\"--prefix\", \"<ABSOLUTE_PATH_TO_LOCAL_JUDGMENTKIT_CHECKOUT>\", \"run\", \"mcp:stdio\"]\n    }\n  }\n}",
      "starter_call": "get_workflow_bundle({ workflow_id: \"workflow.ai-ui-generation\" })"
    },
    {
      "id": "cursor",
      "label": "Cursor",
      "transport": "stdio",
      "connection_label": "Command",
      "connection_value": "npm --prefix <ABSOLUTE_PATH_TO_LOCAL_JUDGMENTKIT_CHECKOUT> run mcp:stdio",
      "config_path": "~/.cursor/mcp.json",
      "install_note": "Save the file and reload Cursor. Use the packaged mcp:stdio script and avoid wrappers that open auxiliary IPC listeners before stdio starts.",
      "config_snippet": "{\n  \"mcpServers\": {\n    \"judgmentkit\": {\n      \"command\": \"npm\",\n      \"args\": [\"--prefix\", \"<ABSOLUTE_PATH_TO_LOCAL_JUDGMENTKIT_CHECKOUT>\", \"run\", \"mcp:stdio\"]\n    }\n  }\n}",
      "starter_call": "get_workflow_bundle({ workflow_id: \"workflow.ai-ui-generation\" })"
    }
