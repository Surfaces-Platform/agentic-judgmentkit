{
  "product_name": "JudgmentKit",
  "surface_label": "MCP operator surface",
  "utility_sentence": "Connect the MCP. Paste the first message. Run the first pass.",
  "run_sequence": ["Connect", "Paste", "Run"],
  "workbench_label": "Run the first pass",
  "workbench_support": "Pick the client, wire in JudgmentKit using the right transport, paste the canonical message, and let the agent start inside the published workflow.",
  "proof_heading": "Generated UI proof",
  "proof_support": "Same brief. One uncontrolled pass and one JudgmentKit-guided pass.",
  "proof_notes": [
    "approved primitives first",
    "bounded runtime",
    "review questions surfaced early"
  ],
  "context_heading": "Loaded context",
  "context_support": "JudgmentKit loads the workflow, linked guardrails, and the calibration example before generation starts.",
  "install_targets": [
    {
      "id": "codex",
      "label": "Codex",
      "transport": "stdio",
      "connection_label": "Transport",
      "connection_value": "npm --prefix <ABSOLUTE_PATH_TO_JUDGMENTKIT_REPO> run mcp:stdio",
      "config_path": "~/.codex/config.toml",
      "install_note": "Run JudgmentKit directly from a local repo checkout. Replace the placeholder path and restart Codex.",
      "config_snippet": "[mcp_servers.judgmentkit]\ncommand = \"npm\"\nargs = [\"--prefix\", \"<ABSOLUTE_PATH_TO_JUDGMENTKIT_REPO>\", \"run\", \"mcp:stdio\"]",
      "starter_call": "get_workflow_bundle({ workflow_id: \"workflow.ai-ui-generation\" })"
    },
    {
      "id": "claude",
      "label": "Claude",
      "transport": "stdio",
      "connection_label": "Command",
      "connection_value": "npm --prefix <ABSOLUTE_PATH_TO_JUDGMENTKIT_REPO> run mcp:stdio",
      "config_path": ".mcp.json",
      "install_note": "Run JudgmentKit directly from a local repo checkout. Replace the placeholder path and restart Claude after adding the server.",
      "config_snippet": "{\n  \"mcpServers\": {\n    \"judgmentkit\": {\n      \"command\": \"npm\",\n      \"args\": [\"--prefix\", \"<ABSOLUTE_PATH_TO_JUDGMENTKIT_REPO>\", \"run\", \"mcp:stdio\"],\n      \"env\": {}\n    }\n  }\n}",
      "starter_call": "get_workflow_bundle({ workflow_id: \"workflow.ai-ui-generation\" })"
    },
    {
      "id": "cursor",
      "label": "Cursor",
      "transport": "stdio",
      "connection_label": "Command",
      "connection_value": "npm --prefix <ABSOLUTE_PATH_TO_JUDGMENTKIT_REPO> run mcp:stdio",
      "config_path": "~/.cursor/mcp.json",
      "install_note": "Run JudgmentKit directly from a local repo checkout. Replace the placeholder path and reopen the workspace if needed.",
      "config_snippet": "{\n  \"mcpServers\": {\n    \"judgmentkit\": {\n      \"command\": \"npm\",\n      \"args\": [\"--prefix\", \"<ABSOLUTE_PATH_TO_JUDGMENTKIT_REPO>\", \"run\", \"mcp:stdio\"]\n    }\n  }\n}",
      "starter_call": "get_workflow_bundle({ workflow_id: \"workflow.ai-ui-generation\" })"
    }
  ],
