{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://judgmentkit.com/schemas/decision-record.schema.json",
  "title": "JudgmentKit Decision Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["decision_id", "occurred_at", "workflow_id", "actor", "context"],
  "properties": {
    "decision_id": {
      "type": "string"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "workflow_id": {
      "type": "string"
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "version"],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "ref": {
          "type": "string"
        },
        "content_type": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "ref": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "text": {
          "type": "string"
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "locale", "risk_level"],
      "properties": {
        "surface": {
          "type": "string"
        },
        "locale": {
          "type": "string"
        },
        "audience": {
          "type": "string"
        },
        "risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "tenant_id": {
          "type": "string"
        }
      }
    },
    "guardrails_considered": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "latency_ms": {
          "type": "number"
        },
        "cost_usd": {
          "type": "number"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model_version": {
          "type": "string"
        },
        "toolchain": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "override_state": {
          "type": "string"
        }
      }
    }
  }
}
